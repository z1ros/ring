// Prisma schema — https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One row per phone number we've ever ringed.
// Phone is the identity — no separate user/account table for MVP.
model Lead {
  id         String     @id @default(cuid())
  phone      String     @unique // E.164, e.g. +14155551234
  email      String? // captured during the call, optional until then
  status     LeadStatus @default(QUEUED)
  vapiCallId String?    @unique // returned when we hand the call off to vapi
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  call Call?

  @@index([status])
  @@index([createdAt])
}

// One row per completed (or attempted) outbound call.
// Created when vapi posts the end-of-call webhook.
model Call {
  id           String    @id @default(cuid())
  leadId       String    @unique
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  startedAt    DateTime?
  endedAt      DateTime?
  durationSec  Int?
  recordingUrl String?
  transcript   String? // full text, plain
  extracted    Json? // slot-filled object: { first_name, age, city, looking_for, ideal_first_date, dealbreakers, references[], consent_record }
  endedReason  String? // 'customer-ended-call' | 'voicemail' | 'assistant-error' | ...
  createdAt    DateTime  @default(now())
}

enum LeadStatus {
  QUEUED // phone captured, call not yet placed
  CALLING // vapi has the call in flight
  COMPLETED // call ended, data extracted
  FAILED // bad number, voicemail-only, hangup before any data
  EMAILED // recap delivered
}
